# Copy to .env on free-arm-vm (~/search-gateway/.env). .env is gitignored.
# All keys optional — each provider activates only when its key is present
# AND its monthly budget cap has room. SearXNG (free) is always the base.

# Exa (free 1,000/mo) — already set on the VM.
EXA_API_KEY=

# Tavily (free 1,000 credits/mo) — get at https://app.tavily.com
TAVILY_API_KEY=

# Gemini "Grounding with Google Search" (free 5,000/mo on Flash).
# Free AI Studio key (separate from a consumer subscription): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: point at a Crawl4AI render container to handle JS-heavy pages in web_read.
# Leave empty to use trafilatura only (default, light on the shared VM).
CRAWL4AI_URL=
